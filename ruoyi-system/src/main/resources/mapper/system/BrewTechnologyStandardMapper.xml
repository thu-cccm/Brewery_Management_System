<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiuchang.system.mapper.BrewTechnologyStandardMapper">
    
    <resultMap type="BrewTechnologyStandard" id="BrewTechnologyStandardResult">
        <result property="standardId"    column="standard_id"    />
        <result property="formulaId"    column="formula_id"    />
        <result property="stageKey"    column="stage_key"    />
        <result property="paramName"    column="param_name"    />
        <result property="paramCode"    column="param_code"    />
        <result property="standardValue"    column="standard_value"    />
        <result property="minValue"    column="min_value"    />
        <result property="maxValue"    column="max_value"    />
        <result property="unit"    column="unit"    />
        <result property="orderNum"    column="order_num"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectBrewTechnologyStandardVo">
        select standard_id, formula_id, stage_key, param_name, param_code, standard_value, min_value, max_value, unit, order_num, remark, create_by, create_time, update_by, update_time from brew_technology_standard
    </sql>

    <select id="selectBrewTechnologyStandardList" parameterType="BrewTechnologyStandard" resultMap="BrewTechnologyStandardResult">
        <include refid="selectBrewTechnologyStandardVo"/>
        <where>  
            <if test="formulaId != null "> and formula_id = #{formulaId}</if>
            <if test="stageKey != null  and stageKey != ''"> and stage_key = #{stageKey}</if>
            <if test="paramName != null  and paramName != ''"> and param_name like concat('%', #{paramName}, '%')</if>
        </where>
        order by order_num
    </select>
    
    <select id="selectBrewTechnologyStandardByStandardId" parameterType="Long" resultMap="BrewTechnologyStandardResult">
        <include refid="selectBrewTechnologyStandardVo"/>
        where standard_id = #{standardId}
    </select>
        
    <insert id="insertBrewTechnologyStandard" parameterType="BrewTechnologyStandard" useGeneratedKeys="true" keyProperty="standardId">
        insert into brew_technology_standard
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="formulaId != null">formula_id,</if>
            <if test="stageKey != null and stageKey != ''">stage_key,</if>
            <if test="paramName != null and paramName != ''">param_name,</if>
            <if test="paramCode != null and paramCode != ''">param_code,</if>
            <if test="standardValue != null and standardValue != ''">standard_value,</if>
            <if test="minValue != null">min_value,</if>
            <if test="maxValue != null">max_value,</if>
            <if test="unit != null">unit,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="formulaId != null">#{formulaId},</if>
            <if test="stageKey != null and stageKey != ''">#{stageKey},</if>
            <if test="paramName != null and paramName != ''">#{paramName},</if>
            <if test="paramCode != null and paramCode != ''">#{paramCode},</if>
            <if test="standardValue != null and standardValue != ''">#{standardValue},</if>
            <if test="minValue != null">#{minValue},</if>
            <if test="maxValue != null">#{maxValue},</if>
            <if test="unit != null">#{unit},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateBrewTechnologyStandard" parameterType="BrewTechnologyStandard">
        update brew_technology_standard
        <trim prefix="SET" suffixOverrides=",">
            <if test="formulaId != null">formula_id = #{formulaId},</if>
            <if test="stageKey != null and stageKey != ''">stage_key = #{stageKey},</if>
            <if test="paramName != null and paramName != ''">param_name = #{paramName},</if>
            <if test="paramCode != null and paramCode != ''">param_code = #{paramCode},</if>
            <if test="standardValue != null and standardValue != ''">standard_value = #{standardValue},</if>
            <if test="minValue != null">min_value = #{minValue},</if>
            <if test="maxValue != null">max_value = #{maxValue},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where standard_id = #{standardId}
    </update>

    <delete id="deleteBrewTechnologyStandardByStandardId" parameterType="Long">
        delete from brew_technology_standard where standard_id = #{standardId}
    </delete>

    <delete id="deleteBrewTechnologyStandardByStandardIds" parameterType="String">
        delete from brew_technology_standard where standard_id in 
        <foreach item="standardId" collection="array" open="(" separator="," close=")">
            #{standardId}
        </foreach>
    </delete>
</mapper>
